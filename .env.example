# Local Development Environment
# Copy this file to .env and fill in your values:
#   cp .env.example .env

NODE_ENV=development

# Home Assistant connection
# Create a Long-Lived Access Token in HA: Profile -> Security -> Long-Lived Access Tokens
SUPERVISOR_TOKEN=your_ha_long_lived_access_token_here
HA_WS_URL=ws://your-ha-ip:8123/api/websocket

# Local paths (defaults work for most setups)
DB_PATH=./dev.db
ASSETS_DIR=./assets

# Server ports (defaults match production)
INGRESS_PORT=8080
EXTERNAL_PORT=8099

# JWT secret for dashboard password auth (any random string).
# Leave blank to have the server generate and persist one on first boot;
# set it explicitly only if you need to share the secret across installs.
JWT_SECRET=
